# Appwrite Function environment variables.
# Set these in Appwrite Console → Functions → Settings → Variables.
# Do NOT commit the actual .env file.

# --- Appwrite (server-to-server access to the locations collection) ---
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69f37144002337d6b4dd
APPWRITE_DATABASE_ID=69f371ae001041d3fa90
APPWRITE_COLLECTION_ID=locations
# Generate a NEW API key in Appwrite Console with scopes:
#   databases.read, documents.read, documents.write
APPWRITE_API_KEY=

# --- OpenWeatherMap (same key used by the MAUI client is fine) ---
OPENWEATHER_API_KEY=

# --- Firebase Admin SDK (paste the WHOLE serviceAccountKey.json content) ---
# IMPORTANT: paste it as a single JSON string with escaped newlines, e.g.:
# {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
FIREBASE_SERVICE_ACCOUNT=
