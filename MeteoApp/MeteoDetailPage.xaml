<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:b="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
             xmlns:local="clr-namespace:MeteoApp"
             x:Class="MeteoApp.MeteoDetailPage"
             Title="{Binding Title}">
	
    <BlazorWebView x:Name="DetailWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type local:Components.MeteoDetail}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>
	
</ContentPage>