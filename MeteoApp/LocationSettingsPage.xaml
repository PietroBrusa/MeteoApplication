<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:MeteoApp.Resources.Strings"
             x:Class="MeteoApp.LocationSettingsPage"
             Title="{x:Static res:AppResources.NotificationsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="{Binding MeteoLocation.Name}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <!-- Master toggle -->
            <Frame CornerRadius="12"
                   Padding="15"
                   HasShadow="True">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.NotificationsEnabledLabel}"
                           VerticalOptions="Center"
                           HorizontalOptions="StartAndExpand"/>
                    <Switch x:Name="EnabledSwitch"
                            IsToggled="{Binding NotificationsEnabled, Mode=TwoWay}"
                            VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Frame>

            <!-- Min threshold -->
            <Frame CornerRadius="12"
                   Padding="15"
                   HasShadow="True"
                   IsEnabled="{Binding Source={x:Reference EnabledSwitch}, Path=IsToggled}">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout>
                        <Label Text="{x:Static res:AppResources.TempThresholdMinLabel}"
                               TextColor="{StaticResource TempCold}"
                               FontAttributes="Bold"
                               HorizontalOptions="StartAndExpand"/>
                        <Label x:Name="MinValueLabel"
                               Text="{Binding TempThresholdMinDisplay}"
                               TextColor="{StaticResource TempCold}"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <Slider x:Name="MinSlider"
                            Minimum="-30"
                            Maximum="50"
                            Value="{Binding TempThresholdMin, Mode=TwoWay}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Max threshold -->
            <Frame CornerRadius="12"
                   Padding="15"
                   HasShadow="True"
                   IsEnabled="{Binding Source={x:Reference EnabledSwitch}, Path=IsToggled}">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout>
                        <Label Text="{x:Static res:AppResources.TempThresholdMaxLabel}"
                               TextColor="{StaticResource TempWarm}"
                               FontAttributes="Bold"
                               HorizontalOptions="StartAndExpand"/>
                        <Label x:Name="MaxValueLabel"
                               Text="{Binding TempThresholdMaxDisplay}"
                               TextColor="{StaticResource TempWarm}"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <Slider x:Name="MaxSlider"
                            Minimum="-30"
                            Maximum="50"
                            Value="{Binding TempThresholdMax, Mode=TwoWay}"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="{x:Static res:AppResources.SaveButton}"
                    Clicked="OnSaveClicked"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
