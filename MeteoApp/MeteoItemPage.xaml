<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:res="clr-namespace:MeteoApp.Resources.Strings"
             xmlns:local="clr-namespace:MeteoApp"
             x:Class="MeteoApp.MeteoItemPage"
             Title="{x:Static res:AppResources.WeatherDetailsTitle}">

    <ScrollView>
        <StackLayout x:Name="MainLayout" Spacing="20" Padding="20">

            <Label Text="{Binding MeteoLocation.Name}"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLocationNameTapped"/>
                </Label.GestureRecognizers>
            </Label>

            <Frame CornerRadius="15"
                   BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                   Padding="20"
                   HasShadow="True">
                <StackLayout Spacing="10" HorizontalOptions="Center">

                    <Label Text="{Binding MeteoLocation.TempDisplay}"
                           FontSize="48"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>

                    <Label Text="{Binding MeteoLocation.WeatherDescription}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray500}"/>

                    <StackLayout Orientation="Horizontal"
                                 HorizontalOptions="Center"
                                 Spacing="30"
                                 Margin="0,10,0,0">

                        <StackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="{x:Static res:AppResources.TempMinLabel}"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource TempCold}"/>
                            <Label Text="{Binding MeteoLocation.TempMinDisplay}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource TempCold}"/>
                        </StackLayout>

                        <StackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="{x:Static res:AppResources.TempMaxLabel}"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource TempWarm}"/>
                            <Label Text="{Binding MeteoLocation.TempMaxDisplay}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource TempWarm}"/>
                        </StackLayout>
                    </StackLayout>

                </StackLayout>
            </Frame>

            <Frame CornerRadius="15"
                   Padding="0"
                   HasShadow="True"
                   HeightRequest="300"
                   IsClippedToBounds="True">

                <maps:Map x:Name="CityMap" />

            </Frame>
        </StackLayout>
    </ScrollView>
</ContentPage>
