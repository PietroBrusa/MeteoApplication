<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MeteoApp.MeteoItemPage"
             Title="Weather Details">

    <ScrollView>
        <StackLayout x:Name="MainLayout" Spacing="20" Padding="20">

            <Label Text="{Binding MeteoLocation.Name}"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center"/>

            <Frame CornerRadius="15"
                   BackgroundColor="#F0F0F0"
                   Padding="20"
                   HasShadow="True">
                <StackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="{Binding MeteoLocation.CurrentTemperature, StringFormat='{0:F1}°C'}"
                           FontSize="48"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="Black"/>
                    <Label Text="{Binding MeteoLocation.WeatherDescription}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           TextColor="DarkGray"/>
                </StackLayout>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="0" 
                   HasShadow="True" 
                   HeightRequest="300" 
                   IsClippedToBounds="True">

                <maps:Map x:Name="CityMap" />

            </Frame>
        </StackLayout>
    </ScrollView>
</ContentPage>