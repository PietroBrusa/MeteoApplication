<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MeteoApp.ViewModels"
             x:Class="MeteoApp.SearchCityPage"
             Title="Cerca Città">

    <ContentPage.BindingContext>
        <vm:SearchCityViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *">
        <SearchBar Grid.Row="0"
                   Placeholder="Inserisci città (es. Milano)"
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}" 
                   Margin="10" />

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding SearchResults}"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="5">
                        <Frame CornerRadius="10" Padding="15" HasShadow="True" BackgroundColor="#2D2D2D">
                            <Grid>
                                <Label Text="{Binding DisplayName}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchCityViewModel}}, Path=SelectCityCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>