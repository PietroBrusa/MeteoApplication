<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:res="clr-namespace:MeteoApp.Resources.Strings"
             x:Class="MeteoApp.SearchCityPage"
             Title="{x:Static res:AppResources.SearchCityTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static res:AppResources.CloseButton}" Clicked="OnCloseClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Ricerca testuale (esistente) -->
        <SearchBar Grid.Row="0"
                   x:Name="CitySearchBar"
                   Placeholder="{x:Static res:AppResources.SearchPlaceholder}"
                   SearchButtonPressed="OnSearchPressed" />

        <!-- Risultati ricerca testuale (altezza limitata per lasciare spazio alla mappa) -->
        <CollectionView Grid.Row="1"
                        x:Name="ResultsCollectionView"
                        MaximumHeightRequest="200"
                        SelectionMode="Single"
                        SelectionChanged="OnCitySelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="10" Orientation="Horizontal">
                        <Label Text="{Binding Name}"
                               FontSize="18"
                               VerticalOptions="Center" />
                        <Label Text="{Binding WeatherDescription}"
                               FontSize="14"
                               HorizontalOptions="EndAndExpand"
                               VerticalOptions="Center" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Separatore tra ricerca testuale e mappa -->
        <Label Grid.Row="2"
               Text="{x:Static res:AppResources.OrSelectFromMap}"
               FontSize="13"
               HorizontalOptions="Center"
               Margin="0,8" />

        <!-- Mappa interattiva per selezionare la città (AS5) -->
        <maps:Map Grid.Row="3"
                  x:Name="SelectionMap"
                  MapClicked="OnMapClicked"
                  MapType="Street" />

        <!-- Barra di conferma: appare dopo il tap sulla mappa -->
        <Frame Grid.Row="4"
               x:Name="ConfirmFrame"
               IsVisible="False"
               CornerRadius="12"
               Padding="15,10"
               Margin="10,5">
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Label x:Name="SelectedCityLabel"
                       FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="FillAndExpand" />
                <Button Text="{x:Static res:AppResources.AddFromMapButton}"
                        Clicked="OnAddFromMapClicked" />
            </StackLayout>
        </Frame>

    </Grid>
</ContentPage>
