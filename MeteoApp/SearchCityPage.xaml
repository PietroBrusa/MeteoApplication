<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.SearchCityPage"
             Title="Cerca Città"
             BackgroundColor="#1E1E1E">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Chiudi" Clicked="OnCloseClicked" />
    </ContentPage.ToolbarItems>

    <StackLayout Padding="15" Spacing="15">

        <SearchBar x:Name="CitySearchBar" 
                   Placeholder="Scrivi il nome di una città..." 
                   SearchButtonPressed="OnSearchPressed"
                   TextColor="White"
                   PlaceholderColor="LightGray"/>

        <CollectionView x:Name="ResultsCollectionView" 
                        SelectionMode="Single"
                        SelectionChanged="OnCitySelected" 
                        BackgroundColor="Transparent">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="10" Orientation="Horizontal">
                        <Label Text="{Binding Name}" FontSize="18" TextColor="White" VerticalOptions="Center" />
                        <Label Text="{Binding WeatherDescription}" FontSize="14" TextColor="LightGray" HorizontalOptions="EndAndExpand" VerticalOptions="Center" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>
</ContentPage>